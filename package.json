{
  "name": "rune-grab",
  "version": "0.1.6",
  "description": "Point at any UI element, grab its context, and send it to Claude, Cursor, Codex, or Claude Code — works with any framework.",
  "type": "module",
  "main": "dist/rune-grab.cjs",
  "module": "dist/rune-grab.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/rune-grab.js",
      "require": "./dist/rune-grab.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./script": "./dist/rune-grab.iife.global.js"
  },
  "bin": {
    "rune-grab": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "vite --config dev/vite.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "grab",
    "ui-inspector",
    "ai",
    "claude",
    "cursor",
    "codex",
    "developer-tools",
    "element-inspector",
    "context-capture"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RuneLtd/rune-grab"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "vite": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "tsup": [
    {
      "entry": {
        "rune-grab": "src/index.ts"
      },
      "format": [
        "esm",
        "cjs"
      ],
      "dts": {
        "entry": "src/index.ts"
      },
      "splitting": false,
      "sourcemap": true,
      "clean": true,
      "minify": false,
      "target": "es2020"
    },
    {
      "entry": {
        "rune-grab.iife": "src/iife.ts"
      },
      "format": [
        "iife"
      ],
      "globalName": "RuneGrab",
      "splitting": false,
      "sourcemap": true,
      "minify": true,
      "target": "es2020"
    },
    {
      "entry": {
        "vite": "src/plugins/vite.ts"
      },
      "format": [
        "esm",
        "cjs"
      ],
      "dts": {
        "entry": "src/plugins/vite.ts"
      },
      "splitting": false,
      "sourcemap": true,
      "external": [
        "vite"
      ],
      "target": "es2020"
    },
    {
      "entry": {
        "react": "src/hooks/react.ts"
      },
      "format": [
        "esm",
        "cjs"
      ],
      "dts": {
        "entry": "src/hooks/react.ts"
      },
      "splitting": false,
      "sourcemap": true,
      "external": [
        "react"
      ],
      "target": "es2020"
    },
    {
      "entry": {
        "cli": "src/cli.ts"
      },
      "format": [
        "esm"
      ],
      "splitting": false,
      "sourcemap": true,
      "target": "node18",
      "banner": {
        "js": "#!/usr/bin/env node"
      }
    }
  ],
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitejs/plugin-vue": "^6.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "svelte": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^7.3.1",
    "vue": "^3.5.0"
  }
}